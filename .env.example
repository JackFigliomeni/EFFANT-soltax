SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Required for fetching transaction history (https://dev.helius.xyz)
HELIUS_API_KEY=

# Where parsed transactions are cached (default: .cache/transactions)
SOLTAX_CACHE_DIR=

# Comma-separated list of additional wallets you own. Transfers between
# owned wallets are classified SELF_TRANSFER (non-taxable movement).
SOLTAX_OWNED_WALLETS=

# Optional: CoinGecko demo API key for higher rate limits on price fetches.
# The free tier works without one.
COINGECKO_API_KEY=
